# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=aiads
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CORS (comma-separated origins when DEBUG=false)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Groq LLM (required for generate endpoints)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase storage (optional — falls back to local /media/)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=pdfs
