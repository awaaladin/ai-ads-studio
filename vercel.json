{
  "version": 2,
  "installCommand": "cd backend && pip install -r requirements.txt",
  "buildCommand": "cd backend && python manage.py collectstatic --noinput && python manage.py migrate --noinput",
  "builds": [
    {
      "src": "backend/config/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/config/wsgi.py"
    }
  ]
}
